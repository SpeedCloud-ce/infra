# SpeedCloud n8n stack — example environment file.
#
# Copy to `.env` next to this file and fill in real values:
#   cp .env.example .env
#
# NEVER commit `.env`. Only `.env.example` (this file, no real secrets) is tracked.
# The compose file (compose/n8n.yml) loads this via `env_file: ../.env.example`
# so the stack boots with safe defaults during smoke tests; for real deployments
# edit `.env.example` to point at `.env` or pass `--env-file .env` at the CLI.

# ---------------------------------------------------------------------------
# Domain / Caddy reverse proxy
# ---------------------------------------------------------------------------

# Public domain n8n is served on. Caddy uses this to request a Let's Encrypt
# certificate. Use a real domain in production; for local smoke tests any
# resolvable hostname works.
N8N_DOMAIN=n8n.example.test

# Email used for ACME (Let's Encrypt) cert notifications. Replace before prod.
CADDY_ACME_EMAIL=devops@speedcloud.example

# Internal upstream (host:port) Caddy forwards to. Defaults to the compose
# service name + container port; only override for non-standard topologies.
N8N_UPSTREAM=n8n:5678

# ---------------------------------------------------------------------------
# n8n core configuration
# ---------------------------------------------------------------------------

# Where n8n believes it is reachable. Must match the public domain when
# behind Caddy so OAuth callbacks and webhook URLs resolve correctly.
N8N_HOST=n8n.example.test
N8N_PORT=5678
N8N_PROTOCOL=https

# Public webhook URL n8n hands out to integrations. Trailing slash matters.
WEBHOOK_URL=https://n8n.example.test/

# Timezone — Brazil-first default. n8n uses this for cron-like nodes and
# scheduled workflows.
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# Encryption key used by n8n to encrypt credentials at rest. MUST be set to a
# stable random value in production (otherwise rotated keys break stored creds).
# Generate with: openssl rand -hex 32
# Leave blank locally to let n8n auto-generate one in the volume; set explicitly
# before going to prod and back it up alongside the n8n_data volume.
N8N_ENCRYPTION_KEY=

# Disable telemetry by default. Flip to true if/when product wants opt-in metrics.
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false

# Runners (n8n 1.69+ recommends task runners for production-grade execution).
N8N_RUNNERS_ENABLED=true
